{
  "name": "social-network-monorepo",
  "version": "1.0.0",
  "description": "Root package for the full-stack social network application.",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "//": "--- INSTALLATION ---",
    "install:all": "npm install --workspaces",
    "//": "--- DEVELOPMENT ---",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "//": "--- PRODUCTION ---",
    "build": "npm run build --workspace=client",
    "start": "npm start --workspace=server",
    "//": "--- UTILITIES & LINTING ---",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "//": "--- DEPLOYMENT (e.g., Heroku) ---",
    "heroku-postbuild": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/social-network.git"
  },
  "keywords": [
    "react",
    "redux",
    "nodejs",
    "express",
    "mongodb",
    "socket.io",
    "tailwindcss",
    "monorepo"
  ],
  "author": "Your Name <you@example.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/your-username/social-network/issues"
  },
  "homepage": "https://github.com/your-username/social-network#readme",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}